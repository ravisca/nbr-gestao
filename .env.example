# ============================================================
# NBR Gestão - Variáveis de Ambiente para Produção
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# Django
# Gere uma nova chave com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-chave-secreta-aqui

DEBUG=False

# IP da VPS e/ou domínio separados por vírgula (sem espaços)
# Exemplo: ALLOWED_HOSTS=123.456.789.0,seu-dominio.com.br
ALLOWED_HOSTS=SEU_IP_AQUI

# ============================================================
# Banco de Dados PostgreSQL
# Descomente e preencha após rodar migrate_to_postgres.sh
# ============================================================
# DB_ENGINE=postgresql
# DB_NAME=nbr_gestao
# DB_USER=nbr_user
# DB_PASSWORD=nbr_password_secure
# DB_HOST=localhost
# DB_PORT=5432
